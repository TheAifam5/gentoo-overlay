+    echo "please run: nvidia-bug-report.sh --domain-name <\"domain_name\">"
+    echo ""
+fi
 usage_bug_report_message
 echo ""
 echo -n "Running $(basename $0)...";
@@ -614,6 +647,74 @@ append_file_or_dir_silent "/etc/nvidia/nvidia-application-profiles-rc"
 append_file_or_dir_silent "/etc/nvidia/nvidia-application-profiles-rc.d"
 append_file_or_dir_silent /usr/share/nvidia/nvidia-application-profiles-*-rc
 
+# append xl information for XEN debugging
+xl_cmd()
+{
+    (
+        cmd=${1}
+        echo "____________________________________________"
+        echo ""
+        echo "xl $cmd"
+        echo ""
+        xl $cmd 2> /dev/null
+        echo ""
+    ) | $GZIP_CMD >> $LOG_FILENAME
+}
+
+# append vGPU related information for XenServer-6.2
+xe_cmd()
+{
+    (
+        cmd=${1}
+        echo "____________________________________________"
+        echo ""
+        echo "xe $cmd params=all"
+        echo ""
+        xe $cmd params=all 2> /dev/null
+        echo ""
+    ) | $GZIP_CMD >> $LOG_FILENAME
+}
+
+if [ -n "$IS_XEN_HYPERVISOR" ]; then
+    xl_cmd "info"
+    xl_cmd "dmesg"
+    xl_cmd "list"
+
+    append "/var/log/xensource.log"
+    append "/var/log/daemon.log"
+
+    xe_cmd "pgpu-list"
+    xe_cmd "gpu-group-list"
+    xe_cmd "vgpu-type-list"
+    xe_cmd "vgpu-list"
+fi
+
+if [ -n "$IS_KVM_HYPERVISOR" ]; then
+    mdev_devices="/sys/class/mdev_bus"
+    (
+        echo "____________________________________________"
+        echo ""
+        echo "Listing GPUs registered to mdev module"
+        echo ""
+        echo_metadata $mdev_devices
+    ) | $GZIP_CMD >> $LOG_FILENAME
+    for phys_gpu in $mdev_devices/*; do
+        vendor_id=`cat $phys_gpu/vendor`
+        if [ "$vendor_id" == "0x10de" ]; then
+            supported_types="$phys_gpu/mdev_supported_types/*"
+            for i in $supported_types; do
+                append "$i/name"
+                append "$i/description"
+                append "$i/available_instances"
+                vgpu_devices="$i/devices"
+                for j in `ls $vgpu_devices 2> /dev/null`; do
+                    append "$vgpu_devices/$j/nvidia/vgpu_params"
+                    append "$vgpu_devices/$j/nvidia/vm_name"
+                done 2>/dev/null
+            done 2>/dev/null
+        fi
+    done 2>/dev/null
+fi
 
 # append ldd info
 
@@ -989,6 +1090,7 @@ for subdir in $proc_module_dirs; do
     for GPU in `ls /proc/driver/nvidia/$subdir/gpus/ 2> /dev/null`; do
         append "/proc/driver/nvidia/$subdir/gpus/$GPU/information"
         append "/proc/driver/nvidia/$subdir/gpus/$GPU/registry"
+        append "/proc/driver/nvidia/$subdir/gpus/$GPU/unbindLock"
     done
     append_glob "/proc/driver/nvidia/$subdir/warnings/*"
     append "/proc/driver/nvidia/$subdir/params"
