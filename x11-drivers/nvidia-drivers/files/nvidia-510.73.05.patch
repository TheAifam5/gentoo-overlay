+                                elif [ "$(echo "$2" | cut -c 1)" = "-" ]; then
+                                    echo "Domain names starting with \"-\" are not supported"
+                                    usage
+                                    exit 1
+                                fi
+                                DOMAIN_NAME=$2
+                                shift
+                                ;;
         * )                     usage
                                 exit 1
     esac
