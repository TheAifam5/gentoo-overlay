description="NVIDIA vGPU Daemon"
command="nvidia-vgpud"
command_args="${NVPD_USER:+--user ${NVPD_USER}} ${ARGS}"
pidfile="/var/run/nvidia-vgpud/nvidia-vgpud.pid"

stop_post() {
	rmdir "${pidfile%/*}" 2>/dev/null || true
}
