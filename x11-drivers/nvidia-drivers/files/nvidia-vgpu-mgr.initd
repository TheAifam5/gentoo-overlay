description="NVIDIA vGPU Manager Daemon"
command="nvidia-vgpu-mgr"
command_args="${NVPD_USER:+--user ${NVPD_USER}} ${ARGS}"
pidfile="/var/run/nvidia-vgpu-mgr/nvidia-vgpu-mgr.pid"

stop_post() {
	rmdir "${pidfile%/*}" 2>/dev/null || true
}
